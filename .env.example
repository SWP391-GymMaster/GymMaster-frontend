# ============================================================================
# GymMaster Frontend — mau bien moi truong. Copy file nay thanh `.env.local`:
#   cp .env.example .env.local
# (.env.local da bi .gitignore, moi nguoi tu giu rieng.)
# ============================================================================

# Google OAuth Client ID (Web) — public, KHONG phai Client Secret.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# --- Chien luoc data: DEV bat mock / PROD dung backend that ---------------
#
# LOCAL DEV  : NEXT_PUBLIC_API_MOCKING=enabled
#              -> MSW chay, UI luon co data gia, khong can backend.
#
# PRODUCTION : KHONG set NEXT_PUBLIC_API_MOCKING (de trong/disabled)
#              + set NEXT_PUBLIC_API_BASE_URL tro toi Cloud Run.
#              -> goi backend that, moi man hinh tu lo loading/empty/error state.
#
# Tren Vercel: dat o Settings > Environment Variables theo tung moi truong
# (Production = real; Preview = co the bat mock neu muon demo nhanh).
# ---------------------------------------------------------------------------

# Bat mock cho local dev (bo comment khi dev offline):
NEXT_PUBLIC_API_MOCKING=enabled

# URL backend that (dung cho PROD; o local chi can khi tat mock de test that):
# NEXT_PUBLIC_API_BASE_URL=https://gymmaster-api-741815287158.asia-southeast1.run.app
